APP_NAME=Alcoholic-BE
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5173,http://localhost:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+)(:\d+)?$
DATABASE_URL=sqlite:///./alcoholic.db
DATABASE_POOL_RECYCLE_SECONDS=1800
RECOMMENDATION_RESPONSE_DELAY_SECONDS=0

# MySQL example. mysql:// is also accepted and normalized to mysql+pymysql://.
# utf8mb4 is appended automatically when charset is omitted.
# DATABASE_URL=mysql+pymysql://root:alcoholic@127.0.0.1:3306/alcoholic?charset=utf8mb4
